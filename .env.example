# API Base URL
VITE_API_BASE_URL=/api

# App Name
VITE_APP_NAME=KnosAI

# App Version
VITE_APP_VERSION=1.0.0

# JWT Secret (required for production)
JWT_SECRET=change-me-to-a-random-secret

# JWT Token Expiry
JWT_EXPIRES_IN=7d

# CORS Allowed Origin (* for all)
# ALLOWED_ORIGIN=https://your-domain.com

# Upstash Redis (optional, leave empty to use in-memory storage)
# Get from: https://console.upstash.com or Vercel Marketplace
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXxx...
